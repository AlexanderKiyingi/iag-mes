# iag-mes — see config/.env.example for full reference
ENVIRONMENT=development
PORT=4003
SERVICE_NAME=mes
DATABASE_URL=postgres://svc_iag_mes:iag_mes_dev@127.0.0.1:6432/iag_platform?sslmode=disable
AUTO_MIGRATE=true

AUTH_MODE=jwt
JWT_ISSUER=http://localhost:3001
JWKS_URL=http://localhost:3001/.well-known/jwks.json
AUDIENCE=iag.mes
SERVICE_CLIENT_ID=iag-mes
SERVICE_CLIENT_SECRET=change-me-in-production

KAFKA_BROKERS=127.0.0.1:19092
KAFKA_CLIENT_ID=iag-mes
KAFKA_CONSUMER_GROUP=iag.mes
KAFKA_PRODUCTION_TOPIC=iag.production
KAFKA_OPERATIONS_TOPIC=iag.operations
KAFKA_SUPPLY_CHAIN_TOPIC=iag.supply-chain
KAFKA_QUALITY_TOPIC=iag.quality
EVENT_BUS_ENABLED=true

INTEGRATIONS_ENABLED=true
UPSTREAM_WAREHOUSE=http://localhost:4005
UPSTREAM_QUALITY_CONTROL=http://localhost:4004
UPSTREAM_ERP=http://localhost:4001
UPSTREAM_SUPPLY_CHAIN=http://localhost:4007
AUTO_WAREHOUSE_ON_RUN_COMPLETE=false
AUTO_QC_ON_RUN_COMPLETE=true
AUTO_VALIDATE_BATCH_SCM=false
